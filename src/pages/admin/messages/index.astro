---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getAuthUser } from '../../../lib/auth';
import { db } from '../../../db';
import { contacts, templates } from '../../../db/schema';
import { desc, eq } from 'drizzle-orm';
import { Mail, Trash2, CheckCheck } from '@lucide/astro';

const user = getAuthUser(Astro.cookies);
if (!user) return Astro.redirect('/admin/login');

const messages = db.select().from(contacts).orderBy(desc(contacts.createdAt)).all();
const allTemplates = db.select({ id: templates.id, title: templates.title }).from(templates).all();
const templateMap = Object.fromEntries(allTemplates.map(t => [t.id, t.title]));
---

<AdminLayout seo={{ title: 'Pesan Masuk', description: '', noIndex: true }} user={user}>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Pesan Masuk</h1>
  </div>

  <div class="space-y-4">
    {messages.length === 0 && (
      <div class="bg-white rounded-xl p-8 text-center text-gray-500 border border-gray-200">
        <Mail class="w-12 h-12 mx-auto mb-3 text-gray-300" />
        <p>Belum ada pesan masuk.</p>
      </div>
    )}
    {messages.map(m => (
      <div class={`bg-white rounded-xl p-6 border transition ${m.isRead ? 'border-gray-200' : 'border-blue-300 shadow-sm'}`}>
        <div class="flex items-start justify-between">
          <div class="flex-1">
            <div class="flex items-center gap-2">
              <h3 class="font-semibold">{m.name}</h3>
              {!m.isRead && <span class="w-2 h-2 bg-blue-500 rounded-full"></span>}
            </div>
            <p class="text-sm text-gray-500">{m.email}{m.phone ? `  |  ${m.phone}` : ''}</p>
            {m.templateId && <p class="text-xs text-blue-600 mt-1">Template: {templateMap[m.templateId] || `#${m.templateId}`}</p>}
          </div>
          <time class="text-xs text-gray-400 shrink-0">{new Date(m.createdAt!).toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</time>
        </div>
        <p class="mt-3 text-gray-700 text-sm whitespace-pre-wrap">{m.message}</p>
        <div class="mt-3 flex gap-2">
          {!m.isRead && (
            <button class="mark-read-btn text-xs text-blue-600 hover:underline flex items-center gap-1" data-id={m.id}>
              <CheckCheck class="w-3.5 h-3.5" /> Tandai sudah dibaca
            </button>
          )}
          <button class="delete-btn text-xs text-red-500 hover:underline flex items-center gap-1" data-id={m.id}>
            <Trash2 class="w-3.5 h-3.5" /> Hapus
          </button>
        </div>
      </div>
    ))}
  </div>
</AdminLayout>

<script>
  document.querySelectorAll('.mark-read-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      try {
        await fetch(`/api/messages/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ isRead: true })
        });
        window.location.reload();
      } catch {}
    });
  });

  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      if (!confirm('Hapus pesan ini?')) return;
      try {
        await fetch(`/api/messages/${id}`, { method: 'DELETE' });
        window.location.reload();
      } catch {}
    });
  });
</script>
