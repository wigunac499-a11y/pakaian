---
import { Menu } from '@lucide/astro';
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2">
        <img src="/logo.svg" alt="Web Pakai" class="h-8" />
      </a>

      <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
        <a href="/" class="hover:text-blue-600 transition">Beranda</a>
        <a href="/template" class="hover:text-blue-600 transition">Template</a>
        <a href="/harga" class="hover:text-blue-600 transition">Harga</a>
        <a href="/testimoni" class="hover:text-blue-600 transition">Testimoni</a>
        <a href="/blog" class="hover:text-blue-600 transition">Blog</a>
        <a href="/faq" class="hover:text-blue-600 transition">FAQ</a>
        <a href="/kontak" class="hover:text-blue-600 transition">Kontak</a>
      </nav>

      <div class="flex items-center gap-3">
        <a href="/kontak" class="hidden md:inline-flex bg-blue-600 text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-blue-700 transition">
          Pesan Sekarang
        </a>

        <button id="menu-toggle" class="md:hidden p-2" aria-label="Toggle menu">
          <Menu class="w-6 h-6" />
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <div class="px-4 py-4 space-y-3 text-sm font-medium">
      <a href="/" class="block py-2 hover:text-blue-600">Beranda</a>
      <a href="/template" class="block py-2 hover:text-blue-600">Template</a>
      <a href="/harga" class="block py-2 hover:text-blue-600">Harga</a>
      <a href="/testimoni" class="block py-2 hover:text-blue-600">Testimoni</a>
      <a href="/blog" class="block py-2 hover:text-blue-600">Blog</a>
      <a href="/faq" class="block py-2 hover:text-blue-600">FAQ</a>
      <a href="/kontak" class="block py-2 hover:text-blue-600">Kontak</a>
      <a href="/kontak" class="block text-center bg-blue-600 text-white px-5 py-2 rounded-full font-semibold">Pesan Sekarang</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
