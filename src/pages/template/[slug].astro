---
import MainLayout from '../../layouts/MainLayout.astro';
import { db } from '../../db';
import { templates } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { ExternalLink, ArrowRight, CheckCircle } from '@lucide/astro';

const { slug } = Astro.params;

const [template] = db.select().from(templates).where(eq(templates.slug, slug!)).all();

if (!template) {
  return Astro.redirect('/404');
}

const features = template.features ? template.features.split('\n').filter(Boolean) : [];
---

<MainLayout seo={{
  title: template.title,
  description: template.description,
  canonical: `${Astro.url.origin}/template/${template.slug}`,
  ogImage: template.image || undefined
}}>
  <section class="py-12 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/template" class="inline-flex items-center gap-1 text-blue-600 hover:underline text-sm mb-6">
        &larr; Kembali ke Template
      </a>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <div class="aspect-video bg-gradient-to-br from-blue-100 to-purple-100 rounded-2xl flex items-center justify-center overflow-hidden">
            {template.image
              ? <img src={template.image} alt={template.title} class="w-full h-full object-cover" />
              : <span class="text-6xl font-bold text-blue-300">{template.title.charAt(0)}</span>
            }
          </div>
        </div>
        <div>
          <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2.5 py-1 rounded-full">{template.category}</span>
          <h1 class="mt-3 text-3xl md:text-4xl font-bold text-gray-900">{template.title}</h1>
          <p class="mt-4 text-gray-600 leading-relaxed">{template.description}</p>

          {features.length > 0 && (
            <div class="mt-6">
              <h3 class="font-semibold text-gray-900 mb-3">Fitur Unggulan:</h3>
              <ul class="space-y-2">
                {features.map(f => (
                  <li class="flex items-start gap-2 text-sm text-gray-600">
                    <CheckCircle class="w-5 h-5 text-green-500 shrink-0 mt-0.5" />
                    <span>{f}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            {template.demoUrl && (
              <a href={template.demoUrl} target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 border-2 border-gray-300 text-gray-700 px-6 py-3 rounded-full font-semibold hover:border-blue-600 hover:text-blue-600 transition">
                <ExternalLink class="w-5 h-5" /> Lihat Demo Live
              </a>
            )}
            <a href={`/kontak?template=${template.id}`}
              class="inline-flex items-center justify-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-full font-semibold hover:bg-blue-700 transition shadow-lg shadow-blue-200">
              Pakai Web Ini <ArrowRight class="w-5 h-5" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Tertarik dengan Template Ini?</h2>
      <p class="text-gray-600 mb-6">Hubungi kami untuk diskusi lebih lanjut dan dapatkan website impian Anda.</p>
      <a href={`/kontak?template=${template.id}`}
        class="inline-flex items-center gap-2 bg-blue-600 text-white px-8 py-3.5 rounded-full font-semibold hover:bg-blue-700 transition shadow-lg shadow-blue-200">
        Pesan Sekarang <ArrowRight class="w-5 h-5" />
      </a>
    </div>
  </section>
</MainLayout>
