---
import MainLayout from '../../layouts/MainLayout.astro';
import { db } from '../../db';
import { templates } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { Search, ArrowRight, Zap, Smartphone, Search as SearchIcon } from '@lucide/astro';

const url = Astro.url;
const kategoriSlug = url.searchParams.get('kategori');
const q = url.searchParams.get('q');

const mapSlugToCategory: Record<string, string> = {
  'e-commerce': 'E-Commerce',
  'company-profile': 'Company Profile',
  'portofolio': 'Portofolio',
  'landing-page': 'Landing Page',
  'blog': 'Blog',
};
const reverseMap: Record<string, string> = Object.fromEntries(
  Object.entries(mapSlugToCategory).map(([k, v]) => [v, k])
);

let allTemplates = db.select().from(templates).where(eq(templates.isPublished, true)).all();

if (kategoriSlug && mapSlugToCategory[kategoriSlug]) {
  allTemplates = allTemplates.filter(t => t.category === mapSlugToCategory[kategoriSlug]);
}
if (q) {
  allTemplates = allTemplates.filter(t =>
    t.title.toLowerCase().includes(q.toLowerCase()) ||
    t.description.toLowerCase().includes(q.toLowerCase())
  );
}

const categories = ['E-Commerce', 'Company Profile', 'Portofolio', 'Landing Page', 'Blog'];
---

<MainLayout seo={{
  title: 'Katalog Template Website Siap Pakai',
  description: 'Jelajahi koleksi template website profesional siap pakai untuk berbagai kebutuhan: E-commerce, Company Profile, Portofolio, dan lainnya.',
  canonical: Astro.url.origin + '/template'
}}>
  <section class="py-12 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-5xl font-bold text-gray-900 mb-4">Katalog Template</h1>
        <p class="text-gray-600 text-lg max-w-2xl mx-auto">
          Pilih template website profesional siap pakai untuk bisnis Anda. Semua template sudah dioptimalkan untuk kecepatan dan SEO.
        </p>
      </div>

      <form method="GET" class="max-w-xl mx-auto mb-8">
        <div class="relative">
          <Search class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" />
          <input type="text" name="q" placeholder="Cari template..." value={q || ''}
            class="w-full pl-12 pr-4 py-3 rounded-full border border-gray-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none" />
        </div>
      </form>

      <div class="flex flex-wrap gap-2 justify-center mb-10">
        <a href="/template" class={`px-4 py-2 rounded-full text-sm font-medium transition ${!kategoriSlug ? 'bg-blue-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100 border'}`}>Semua</a>
        {categories.map(cat => {
          const slug = reverseMap[cat];
          return <a href={`/template?kategori=${slug}`} class={`px-4 py-2 rounded-full text-sm font-medium transition ${kategoriSlug === slug ? 'bg-blue-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100 border'}`}>{cat}</a>;
        })}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {allTemplates.length === 0 && (
          <div class="col-span-full text-center py-16 text-gray-500">
            <p class="text-lg">Belum ada template untuk kategori ini.</p>
            <a href="/template" class="text-blue-600 hover:underline mt-2 inline-block">Lihat semua template</a>
          </div>
        )}
        {allTemplates.map(t => (
          <a href={`/template/${t.slug}`} class="group bg-white rounded-2xl overflow-hidden border border-gray-100 hover:shadow-xl transition-all hover:-translate-y-1">
            <div class="aspect-video bg-gradient-to-br from-blue-50 to-purple-50 overflow-hidden">
              {t.image
                ? <img src={t.image} alt={t.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                : <div class="w-full h-full flex items-center justify-center"><span class="text-4xl font-bold text-blue-300">{t.title.charAt(0)}</span></div>
              }
            </div>
            <div class="p-5">
              <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2.5 py-1 rounded-full">{t.category}</span>
              <h2 class="mt-2 text-lg font-bold text-gray-900 group-hover:text-blue-600 transition">{t.title}</h2>
              <p class="mt-1 text-gray-600 text-sm line-clamp-2">{t.description}</p>
              <div class="mt-4 flex items-center justify-between pt-4 border-t border-gray-50">
                <span class="text-sm font-semibold text-gray-900">{t.price || 'Hubungi Kami'}</span>
                <span class="inline-flex items-center gap-1 text-blue-600 font-semibold text-sm group-hover:gap-2 transition-all">Detail <ArrowRight class="w-4 h-4" /></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
