---
import MainLayout from '../layouts/MainLayout.astro';
import { Mail, Phone, MapPin, Send } from '@lucide/astro';

const templateId = Astro.url.searchParams.get('template');
---

<MainLayout seo={{
  title: 'Hubungi Kami',
  description: 'Hubungi tim Web Pakai untuk konsultasi gratis pembuatan website. Isi form pemesanan dan kami akan menghubungi Anda dalam 1x24 jam.',
  canonical: Astro.url.origin + '/kontak'
}}>
  <section class="py-12 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-5xl font-bold text-gray-900 mb-4">Hubungi Kami</h1>
        <p class="text-gray-600 text-lg max-w-2xl mx-auto">
          Isi form di bawah dan tim kami akan menghubungi Anda dalam 1x24 jam untuk diskusi lebih lanjut.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-4xl mx-auto">
        <div>
          <form id="contact-form" class="space-y-5">
            <input type="hidden" name="template_id" value={templateId || ''} />
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Nama Lengkap <span class="text-red-500">*</span></label>
              <input type="text" id="name" name="name" required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email <span class="text-red-500">*</span></label>
              <input type="email" id="email" name="email" required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">No. WhatsApp</label>
              <input type="tel" id="phone" name="phone"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Pesan <span class="text-red-500">*</span></label>
              <textarea id="message" name="message" rows="5" required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none"></textarea>
            </div>
            <button type="submit"
              class="w-full bg-blue-600 text-white px-6 py-3.5 rounded-xl font-semibold hover:bg-blue-700 transition shadow-lg shadow-blue-200 flex items-center justify-center gap-2">
              <Send class="w-5 h-5" /> Kirim Pesan
            </button>
            <p id="form-status" class="text-center text-sm mt-2"></p>
          </form>
        </div>

        <div class="space-y-6">
          <div class="bg-gray-50 rounded-2xl p-6">
            <h3 class="font-semibold text-lg mb-4">Informasi Kontak</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <Mail class="w-5 h-5 text-blue-600 mt-0.5" />
                <div>
                  <p class="font-medium text-sm">Email</p>
                  <p class="text-gray-600 text-sm">hello@webpakai.com</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Phone class="w-5 h-5 text-blue-600 mt-0.5" />
                <div>
                  <p class="font-medium text-sm">WhatsApp</p>
                  <p class="text-gray-600 text-sm">+62 812-3456-7890</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <MapPin class="w-5 h-5 text-blue-600 mt-0.5" />
                <div>
                  <p class="font-medium text-sm">Lokasi</p>
                  <p class="text-gray-600 text-sm">Indonesia</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-blue-50 rounded-2xl p-6">
            <h3 class="font-semibold text-lg mb-2">Proses Cepat</h3>
            <ol class="space-y-2 text-sm text-gray-700">
              <li class="flex gap-2"><span class="font-bold text-blue-600">1.</span> Konsultasi kebutuhan via WhatsApp</li>
              <li class="flex gap-2"><span class="font-bold text-blue-600">2.</span> Pemilihan template dan kustomisasi</li>
              <li class="flex gap-2"><span class="font-bold text-blue-600">3.</span> Proses pembuatan (3-7 hari kerja)</li>
              <li class="flex gap-2"><span class="font-bold text-blue-600">4.</span> Website live dan siap digunakan</li>
            </ol>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    status.textContent = 'Mengirim...';
    status.className = 'text-center text-sm mt-2 text-gray-500';

    const data = new FormData(form);
    const body = Object.fromEntries(data.entries());

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const result = await res.json();
      if (res.ok) {
        status.textContent = 'Pesan berhasil dikirim! Kami akan menghubungi Anda segera.';
        status.className = 'text-center text-sm mt-2 text-green-600 font-medium';
        form.reset();
      } else {
        status.textContent = result.error || 'Gagal mengirim pesan. Silakan coba lagi.';
        status.className = 'text-center text-sm mt-2 text-red-500';
      }
    } catch {
      status.textContent = 'Terjadi kesalahan. Silakan coba lagi.';
      status.className = 'text-center text-sm mt-2 text-red-500';
    }
  });
</script>
