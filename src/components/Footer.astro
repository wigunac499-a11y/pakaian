---
import { Globe, Mail, MapPin } from '@lucide/astro';
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-white font-bold text-lg mb-4">Web Pakai</h3>
        <p class="text-sm leading-relaxed">
          Platform pembuatan website instan dengan template siap pakai. Cepat, responsif, dan SEO-friendly untuk bisnis Anda.
        </p>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4">Navigasi</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/template" class="hover:text-white transition">Template Website</a></li>
          <li><a href="/blog" class="hover:text-white transition">Blog & Edukasi</a></li>
          <li><a href="/kontak" class="hover:text-white transition">Hubungi Kami</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4">Kontak</h4>
        <ul class="space-y-3 text-sm">
          <li class="flex items-center gap-2">
            <Mail class="w-4 h-4 text-blue-400" />
            <span>hello@webpakai.com</span>
          </li>
          <li class="flex items-center gap-2">
            <MapPin class="w-4 h-4 text-blue-400" />
            <span>Indonesia</span>
          </li>
        </ul>
      </div>
    </div>
    <div class="border-t border-gray-800 mt-8 pt-8 text-center text-sm text-gray-500">
      &copy; {new Date().getFullYear()} Web Pakai. All rights reserved.
    </div>
  </div>
</footer>
