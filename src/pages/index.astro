---
import MainLayout from '../layouts/MainLayout.astro';
import { ArrowRight, Zap, Layout, Search, Shield, Star, ChevronRight } from '@lucide/astro';

const features = [
  { img: '/images/feature-speed.svg', title: 'Super Cepat', desc: 'Loading instan dengan skor Core Web Vitals 100%' },
  { img: '/images/feature-design.svg', title: 'Desain Modern', desc: 'Template profesional yang bisa dikustomisasi' },
  { img: '/images/feature-seo.svg', title: 'SEO Optimal', desc: 'Struktur website ramah mesin pencari' },
  { img: '/images/feature-shield.svg', title: 'Aman & Handal', desc: 'Keamanan terjamin dengan validasi server-side' },
];
---

<MainLayout seo={{
  title: 'Platform Pembuatan Website Instan',
  description: 'Buat website impian Anda dalam hitungan menit dengan template siap pakai. Cepat, responsif, SEO-friendly, tanpa coding.'
}}>
  <section class="relative overflow-hidden bg-gradient-to-br from-blue-50 via-white to-purple-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center py-16 md:py-24">
        <div>
          <span class="text-xs font-semibold text-blue-600 bg-blue-100 px-3 py-1.5 rounded-full">Platform Website No. 1 di Indonesia</span>
          <h1 class="mt-6 text-4xl md:text-6xl font-bold tracking-tight text-gray-900 leading-tight">
            Website Impian Anda,{' '}
            <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">Siap Pakai</span>
          </h1>
          <p class="mt-6 text-lg md:text-xl text-gray-600 leading-relaxed">
            Platform pembuatan website instan dengan template profesional siap pakai. Tanpa coding, cepat loading, dan optimal untuk SEO.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <a href="/template" class="inline-flex items-center justify-center gap-2 bg-blue-600 text-white px-8 py-3.5 rounded-full text-base font-semibold hover:bg-blue-700 transition shadow-lg shadow-blue-200">
              Lihat Template <ArrowRight class="w-5 h-5" />
            </a>
            <a href="/kontak" class="inline-flex items-center justify-center gap-2 border-2 border-gray-300 text-gray-700 px-8 py-3.5 rounded-full text-base font-semibold hover:border-blue-600 hover:text-blue-600 transition">
              Konsultasi Gratis
            </a>
          </div>
          <div class="mt-8 flex items-center gap-6 text-sm text-gray-500">
            <div class="flex items-center gap-1"><Star class="w-4 h-4 fill-yellow-400 text-yellow-400" /><Star class="w-4 h-4 fill-yellow-400 text-yellow-400" /><Star class="w-4 h-4 fill-yellow-400 text-yellow-400" /><Star class="w-4 h-4 fill-yellow-400 text-yellow-400" /><Star class="w-4 h-4 fill-yellow-400 text-yellow-400" /></div>
            <span>4.9/5 dari 200+ klien</span>
          </div>
        </div>
        <div class="relative">
          <img src="/images/hero-illustration.svg" alt="Web Pakai Illustration" class="w-full" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Kenapa Memilih Web Pakai?</h2>
        <p class="mt-4 text-gray-600 text-lg">Kami menggabungkan kecepatan, desain, dan SEO dalam satu platform</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {features.map(f => (
          <div class="text-center p-6 group hover:bg-gray-50 rounded-2xl transition">
            <img src={f.img} alt={f.title} class="w-24 h-24 mx-auto mb-4" loading="lazy" />
            <h3 class="font-semibold text-lg mb-2">{f.title}</h3>
            <p class="text-gray-600 text-sm">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Kategori Template</h2>
        <p class="mt-4 text-gray-600 text-lg">Pilih template sesuai kebutuhan bisnis Anda</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/template?kategori=e-commerce" class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-blue-500 to-blue-700 p-8 text-white min-h-[200px] flex flex-col justify-end">
          <img src="/templates/toko-online.svg" alt="" class="absolute inset-0 w-full h-full object-cover opacity-20" />
          <h3 class="text-2xl font-bold mb-2 relative">E-Commerce</h3>
          <p class="text-blue-100 text-sm mb-4 relative">Template toko online siap pakai</p>
          <span class="inline-flex items-center gap-1 text-sm font-semibold group-hover:gap-2 transition-all relative">Lihat Template <ArrowRight class="w-4 h-4" /></span>
        </a>
        <a href="/template?kategori=company-profile" class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-purple-500 to-purple-700 p-8 text-white min-h-[200px] flex flex-col justify-end">
          <img src="/templates/company-profile.svg" alt="" class="absolute inset-0 w-full h-full object-cover opacity-20" />
          <h3 class="text-2xl font-bold mb-2 relative">Company Profile</h3>
          <p class="text-purple-100 text-sm mb-4 relative">Website profil perusahaan profesional</p>
          <span class="inline-flex items-center gap-1 text-sm font-semibold group-hover:gap-2 transition-all relative">Lihat Template <ArrowRight class="w-4 h-4" /></span>
        </a>
        <a href="/template?kategori=portofolio" class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-green-500 to-green-700 p-8 text-white min-h-[200px] flex flex-col justify-end">
          <img src="/templates/portofolio.svg" alt="" class="absolute inset-0 w-full h-full object-cover opacity-20" />
          <h3 class="text-2xl font-bold mb-2 relative">Portofolio</h3>
          <p class="text-green-100 text-sm mb-4 relative">Portofolio pribadi atau kreatif</p>
          <span class="inline-flex items-center gap-1 text-sm font-semibold group-hover:gap-2 transition-all relative">Lihat Template <ArrowRight class="w-4 h-4" /></span>
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <img src="/images/og-default.svg" alt="Web Pakai" class="max-w-md mx-auto mb-8 rounded-2xl shadow-lg" loading="lazy" />
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Siap Membangun Website Anda?</h2>
      <p class="text-gray-600 text-lg mb-8 max-w-2xl mx-auto">Tim kami siap membantu Anda dari awal hingga website live. Konsultasi gratis tanpa kewajiban.</p>
      <a href="/kontak" class="inline-flex items-center gap-2 bg-blue-600 text-white px-8 py-3.5 rounded-full text-base font-semibold hover:bg-blue-700 transition shadow-lg shadow-blue-200">
        Hubungi Kami Sekarang <ArrowRight class="w-5 h-5" />
      </a>
    </div>
  </section>
</MainLayout>
