---
import MainLayout from '../../layouts/MainLayout.astro';
import { db } from '../../db';
import { templates } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { ExternalLink, ArrowRight, CheckCircle, Monitor, Smartphone, Zap, Search } from '@lucide/astro';

const { slug } = Astro.params;
const [template] = db.select().from(templates).where(eq(templates.slug, slug!)).all();

if (!template) return Astro.redirect('/404');

const features = template.features ? template.features.split('\n').filter(Boolean) : [];
const specs = [
  { icon: Monitor, label: 'Tampilan Desktop' },
  { icon: Smartphone, label: 'Responsive Mobile' },
  { icon: Zap, label: 'Kecepatan Optimal' },
  { icon: Search, label: 'SEO-Friendly' },
];
---

<MainLayout seo={{
  title: template.title, description: template.description,
  canonical: `${Astro.url.origin}/template/${template.slug}`,
  ogImage: template.image || undefined
}}>
  <section class="pt-8 pb-0">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/template" class="inline-flex items-center gap-1 text-blue-600 hover:underline text-sm mb-6">&larr; Kembali ke Template</a>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-3 py-1.5 rounded-full">{template.category}</span>
          <h1 class="mt-4 text-3xl md:text-5xl font-bold text-gray-900 leading-tight">{template.title}</h1>
          <p class="mt-4 text-gray-600 leading-relaxed text-lg">{template.description}</p>

          <div class="mt-6 flex flex-wrap gap-3">
            {specs.map(s => {
              const Icon = s.icon;
              return <span class="flex items-center gap-1.5 text-sm text-gray-500 bg-gray-50 px-3 py-1.5 rounded-full"><Icon class="w-4 h-4" />{s.label}</span>;
            })}
          </div>

          <div class="flex items-center gap-4 mt-8">
            <span class="text-2xl font-bold text-gray-900">{template.price}</span>
            <span class="text-sm text-gray-400">/tahun</span>
          </div>

          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <a href={`/kontak?template=${template.id}`}
              class="inline-flex items-center justify-center gap-2 bg-blue-600 text-white px-8 py-3.5 rounded-full font-semibold hover:bg-blue-700 transition shadow-lg shadow-blue-200 text-base">
              Pesan Template Ini <ArrowRight class="w-5 h-5" />
            </a>
            {template.demoUrl && (
              <a href={template.demoUrl} target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 border-2 border-gray-300 text-gray-700 px-8 py-3.5 rounded-full font-semibold hover:border-blue-600 hover:text-blue-600 transition text-base">
                <ExternalLink class="w-5 h-5" /> Lihat Demo
              </a>
            )}
          </div>
        </div>

        <div class="relative">
          <div class="aspect-video rounded-2xl overflow-hidden shadow-2xl border border-gray-200 bg-white">
            {template.image
              ? <img src={template.image} alt={template.title} class="w-full h-full object-cover" />
              : <div class="w-full h-full bg-gradient-to-br from-blue-100 to-purple-100 flex items-center justify-center"><span class="text-6xl font-bold text-blue-300">{template.title.charAt(0)}</span></div>
            }
          </div>
          <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-blue-600 rounded-full flex items-center justify-center shadow-lg hidden md:flex">
            <span class="text-white text-sm font-bold text-center leading-tight">PREMIUM<br/>TEMPLATE</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Fitur Unggulan</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {features.map(f => (
              <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl">
                <CheckCircle class="w-5 h-5 text-green-500 shrink-0 mt-0.5" />
                <span class="text-gray-700 text-sm">{f}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-gradient-to-br from-blue-600 to-purple-600 rounded-2xl p-6 text-white">
          <h3 class="font-bold text-lg mb-2">Tertarik dengan Template Ini?</h3>
          <p class="text-sm text-blue-100 mb-4">Dapatkan website impian Anda dalam hitungan hari. Konsultasi gratis tanpa kewajiban.</p>
          <ul class="space-y-2 text-sm mb-6">
            <li class="flex items-center gap-2"><CheckCircle class="w-4 h-4 text-blue-200" /> Kustomisasi sesuai branding</li>
            <li class="flex items-center gap-2"><CheckCircle class="w-4 h-4 text-blue-200" /> Gratis hosting 1 tahun</li>
            <li class="flex items-center gap-2"><CheckCircle class="w-4 h-4 text-blue-200" /> Support 24/7</li>
            <li class="flex items-center gap-2"><CheckCircle class="w-4 h-4 text-blue-200" /> Garansi kepuasan 100%</li>
          </ul>
          <a href={`/kontak?template=${template.id}`}
            class="block text-center bg-white text-blue-600 px-6 py-3 rounded-full font-semibold hover:bg-blue-50 transition">
            Konsultasi Gratis
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Siap Mulai?</h2>
      <p class="text-gray-600 mb-8 max-w-xl mx-auto">Hubungi tim kami sekarang dan dapatkan website profesional untuk bisnis Anda.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`/kontak?template=${template.id}`}
          class="inline-flex items-center gap-2 bg-blue-600 text-white px-8 py-3.5 rounded-full font-semibold hover:bg-blue-700 transition shadow-lg shadow-blue-200">Pesan Sekarang <ArrowRight class="w-5 h-5" /></a>
        <a href="/harga"
          class="inline-flex items-center gap-2 border-2 border-gray-300 text-gray-700 px-8 py-3.5 rounded-full font-semibold hover:border-blue-600 hover:text-blue-600 transition">Lihat Paket Harga</a>
      </div>
    </div>
  </section>
</MainLayout>
