---
import '../styles/global.css';
import { buildSEO, type SEOProps } from '../lib/seo';

export interface Props {
  seo?: SEOProps;
  user?: { username: string };
}

const { seo, user } = Astro.props;
const meta = buildSEO(seo || { title: 'Dashboard', description: '' });
const nav = [
  { href: '/admin', label: 'Dashboard', icon: 'LayoutDashboard' },
  { href: '/admin/templates', label: 'Template', icon: 'Layout' },
  { href: '/admin/blog', label: 'Blog', icon: 'FileText' },
  { href: '/admin/testimonials', label: 'Testimoni', icon: 'Star' },
  { href: '/admin/faqs', label: 'FAQ', icon: 'HelpCircle' },
  { href: '/admin/messages', label: 'Pesan', icon: 'Mail' },
  { href: '/admin/subscribers', label: 'Subscribers', icon: 'Users' },
  { href: '/admin/admins', label: 'Admin', icon: 'Shield' },
];
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{meta.title}</title>
  </head>
  <body class="bg-gray-100 text-gray-900 antialiased flex min-h-screen">
    <nav class="bg-gray-900 text-white w-56 shrink-0 flex flex-col hidden md:flex">
      <div class="p-4 border-b border-gray-800">
        <a href="/admin" class="font-bold text-lg">Web Pakai Admin</a>
      </div>
      <div class="flex-1 p-3 space-y-1 overflow-y-auto text-sm">
        {nav.map(n => (
          <a href={n.href} class={`flex items-center gap-2 px-3 py-2 rounded-lg transition ${Astro.url.pathname === n.href ? 'bg-blue-600 text-white' : 'text-gray-400 hover:text-white hover:bg-gray-800'}`}>
            {n.label}
          </a>
        ))}
      </div>
      <div class="p-4 border-t border-gray-800 text-sm">
        {user && <div class="text-gray-400 mb-2">{user.username}</div>}
        <a href="/" class="block text-gray-400 hover:text-white mb-1">Lihat Situs</a>
        <a href="/api/logout" class="text-red-400 hover:text-red-300">Logout</a>
      </div>
    </nav>

    <div class="flex-1 flex flex-col min-h-screen">
      <nav class="bg-white border-b border-gray-200 px-4 py-3 flex items-center justify-between md:hidden">
        <a href="/admin" class="font-bold text-gray-900">Web Pakai Admin</a>
        <div class="flex items-center gap-3 text-sm">
          {user && <span class="text-gray-500">{user.username}</span>}
          <a href="/api/logout" class="text-red-500">Logout</a>
        </div>
      </nav>
      <main class="flex-1 p-4 md:p-6 max-w-6xl mx-auto w-full">
        <slot />
      </main>
    </div>
  </body>
</html>
