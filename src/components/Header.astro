---
import { Menu, X } from '@lucide/astro';
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2">
        <span class="text-2xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">Web Pakai</span>
      </a>

      <nav class="hidden md:flex items-center gap-8 text-sm font-medium">
        <a href="/" class="hover:text-blue-600 transition">Beranda</a>
        <a href="/template" class="hover:text-blue-600 transition">Template</a>
        <a href="/blog" class="hover:text-blue-600 transition">Blog</a>
        <a href="/kontak" class="hover:text-blue-600 transition">Kontak</a>
      </nav>

      <a href="/kontak" class="hidden md:inline-flex bg-blue-600 text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-blue-700 transition">
        Pesan Sekarang
      </a>

      <button id="menu-toggle" class="md:hidden p-2" aria-label="Toggle menu">
        <Menu class="w-6 h-6" />
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <div class="px-4 py-4 space-y-3 text-sm font-medium">
      <a href="/" class="block py-2 hover:text-blue-600">Beranda</a>
      <a href="/template" class="block py-2 hover:text-blue-600">Template</a>
      <a href="/blog" class="block py-2 hover:text-blue-600">Blog</a>
      <a href="/kontak" class="block py-2 hover:text-blue-600">Kontak</a>
      <a href="/kontak" class="block text-center bg-blue-600 text-white px-5 py-2 rounded-full font-semibold">
        Pesan Sekarang
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
